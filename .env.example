# Optional Better Auth-compatible backend origin.
VITE_BETTER_AUTH_URL=http://localhost:8787

# Optional override used when building auth callback URLs outside the browser.
VITE_APP_ORIGIN=http://localhost:1420

# Used by the meeting recorder's Rust/OpenAI transcription pipeline.
OPENAI_API_KEY=your_openai_api_key_here

# Supported as a fallback by the Rust transcription pipeline.
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Optional API key for the companion AI route handlers in src/app/api.
AI_GATEWAY_API_KEY=your_ai_gateway_api_key_here
