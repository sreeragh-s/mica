# Copy to .env — same base URL as backend BETTER_AUTH_URL (Worker URL or tunnel).
VITE_AUTH_URL=https://your-worker.example.workers.dev

# Optional: show speech-to-text mic in the editor toolbar (Web Speech API).
# VITE_ENABLE_SPEECH_TO_TEXT=true

# Optional: show share-content control in the editor toolbar.
# VITE_ENABLE_SHARE_CONTENT=true
