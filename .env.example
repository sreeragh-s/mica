# Frontend (VITE_* vars are bundled — no secrets)
VITE_BETTER_AUTH_URL=http://localhost:8787
VITE_APP_ORIGIN=http://localhost:1420

# Companion API (server-side, optional)
AI_GATEWAY_API_KEY=your_ai_gateway_api_key_here

# Release signing — export in shell before `npm run release` (see docs/RELEASE.md)
# TAURI_SIGNING_PRIVATE_KEY=
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
