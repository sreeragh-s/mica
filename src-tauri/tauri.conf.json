{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mica",
  "version": "0.1.0",
  "identifier": "com.mica.io",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mica",
        "width": 800,
        "height": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 12,
          "y": 18
        },
        "dragDropEnabled": false,
        "backgroundColor": "#0a0a0a"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$HOME/**",
            "$DESKTOP/**",
            "$DOCUMENT/**",
            "$DOWNLOAD/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "publisher": "Mica",
    "category": "Productivity",
    "shortDescription": "Local-first notes workspace with Git and AI chat.",
    "longDescription": "Mica is a local-first Tauri notes workspace with wiki links, Git flows, and CLI AI chat.",
    "copyright": "Copyright © Mica contributors",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "14.4"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "allowDowngrades": true,
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["English"]
      },
      "wix": {
        "language": "en-US"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/sreeragh-s/mica/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIwQkI5NDdBM0VBOEQzNDgKUldSSTA2ZytlcFM3SU1BMEsySmk1TTVxdDVvUmNoYUhpeGVNYWY4OGJiYTFxNVNuWFA5bEk0KzMK"
    }
  }
}
