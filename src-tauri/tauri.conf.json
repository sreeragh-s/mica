{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "notelab-tauri",
  "version": "0.1.0",
  "identifier": "com.notelab.io",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "notelab-tauri",
        "width": 800,
        "height": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 12,
          "y": 18
        },
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$HOME/**",
            "$DESKTOP/**",
            "$DOCUMENT/**",
            "$DOWNLOAD/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "14.4"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/sreeragh-s/notelab/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIwQkI5NDdBM0VBOEQzNDgKUldSSTA2ZytlcFM3SU1BMEsySmk1TTVxdDVvUmNoYUhpeGVNYWY4OGJiYTFxNVNuWFA5bEk0KzMK"
    }
  }
}
